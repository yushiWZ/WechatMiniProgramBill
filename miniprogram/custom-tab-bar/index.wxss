.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: #ffffff;
  border-top: 1rpx solid #eeeeee;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 0 6rpx;
}

.tab-icon {
  font-size: 40rpx;
  margin-bottom: 2rpx;
}

.tab-text {
  font-size: 32rpx;
  color: #999999;
}

.tab-text.active {
  color: #07c160;
  font-weight: bold;
}
