.page {
  padding: 20rpx;
  padding-bottom: 60rpx;
}

/* 类型切换 */
.type-toggle {
  display: flex;
  background: #f0f0f0;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
}

.toggle-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 34rpx;
  color: #666;
  transition: all 0.3s;
}

.toggle-item.active {
  color: #fff;
  font-weight: bold;
}

.toggle-item.active.expense { background: #e74c3c; }
.toggle-item.active.income { background: #07c160; }

/* 分类 */
.section-title {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.category-item {
  width: calc(25% - 12rpx);
  text-align: center;
  padding: 20rpx 0;
  background: #fff;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.category-item.selected {
  border-color: #07c160;
  background: #f0fff4;
}

.cat-icon {
  display: block;
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.cat-name {
  font-size: 28rpx;
  color: #666;
}

/* 金额输入 */
.amount-box {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 30rpx;
}

.currency {
  font-size: 52rpx;
  font-weight: bold;
  color: #333;
  margin-right: 12rpx;
}

.amount-input {
  flex: 1;
  font-size: 52rpx;
  font-weight: bold;
}

/* 表单项 */
.form-row {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-radius: 12rpx;
}

.form-label {
  font-size: 34rpx;
  color: #333;
  width: 120rpx;
}

.form-value {
  font-size: 34rpx;
  color: #666;
}

.form-input {
  flex: 1;
  font-size: 34rpx;
}

/* 保存按钮 */
.save-btn {
  margin-top: 40rpx;
  background: #07c160;
  color: #fff;
  font-size: 36rpx;
  border-radius: 12rpx;
}

.save-btn[disabled] {
  background: #ccc;
}

.delete-btn {
  margin-top: 20rpx;
  background: #fff;
  color: #e74c3c;
  font-size: 32rpx;
  border: 1rpx solid #e74c3c;
  border-radius: 12rpx;
}
