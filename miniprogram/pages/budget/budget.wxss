.page {
  padding: 20rpx;
}

.section {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.s-label {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 12rpx;
  display: block;
}

.s-value {
  font-size: 34rpx;
  color: #333;
}

.picker-val {
  color: #07c160;
  font-weight: bold;
}

.amount-box {
  display: flex;
  align-items: center;
}

.currency {
  font-size: 44rpx;
  font-weight: bold;
  margin-right: 12rpx;
}

.amount-input {
  flex: 1;
  font-size: 44rpx;
  font-weight: bold;
}

.spent-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #e74c3c;
}

.progress-bar {
  height: 20rpx;
  background: #f0f0f0;
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.progress-fill {
  height: 100%;
  background: #07c160;
  border-radius: 10rpx;
  transition: width 0.3s;
}

.progress-fill.over { background: #e74c3c; }

.percent-text {
  font-size: 32rpx;
  color: #666;
}

.save-btn {
  margin-top: 30rpx;
  background: #07c160;
  color: #fff;
  font-size: 36rpx;
  border-radius: 12rpx;
}
