/* ============================================================
 * 预算设置页面样式 (budget.wxss)
 * ============================================================
 * 采用卡片式布局，每个功能区域为独立的白色圆角卡片：
 *   - 浅灰背景（由全局 app.wxss 设定）
 *   - 每个 section 卡片带轻微阴影，增强层次感
 *   - 主色调：绿色 #07c160（正常/预算），红色 #e74c3c（支出/超支）
 * ============================================================ */

/* 页面容器：四周均匀留白 */
.page {
  padding: 20rpx;
}

/* ===== 通用卡片区块 =====
 * 每个 section 为独立的白色圆角卡片，底部有轻微阴影。
 * 卡片之间通过 margin-bottom 保持间距。 */
.section {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

/* 卡片标题/标签：灰色小字，位于卡片内容上方 */
.s-label {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 12rpx;
  display: block;
}

/* 卡片内容值：深色正常大小文字 */
.s-value {
  font-size: 34rpx;
  color: #333;
}

/* 月份选择器的值：绿色加粗，提示用户可点击切换 */
.picker-val {
  color: #07c160;
  font-weight: bold;
}

/* ===== 金额输入区域 =====
 * ¥ 符号和输入框横向排列，使用 flex 布局实现左固定右自适应。 */
.amount-box {
  display: flex;
  align-items: center;
}

.currency {
  font-size: 44rpx;
  font-weight: bold;
  margin-right: 12rpx;
}

.amount-input {
  flex: 1;
  font-size: 44rpx;
  font-weight: bold;
}

/* ===== 已支出金额 =====
 * 红色加粗大号字体，与预算金额形成视觉对比，
 * 帮助用户快速判断支出与预算的关系。 */
.spent-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #e74c3c;
}

/* ===== 预算使用进度条 =====
 * 灰色背景的圆角条形容器，内部填充条宽度由 JS 动态设置。
 * 填充条颜色逻辑：
 *   - 默认绿色 → 使用率 <= 80%（正常）
 *   - 红色（over 类名）→ 使用率 > 80%（预警/超支）
 * 宽度上限为 100%，即使超支也不会溢出容器。 */
.progress-bar {
  height: 20rpx;
  background: #f0f0f0;
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.progress-fill {
  height: 100%;
  background: #07c160;
  border-radius: 10rpx;
  transition: width 0.3s;
}

/* 超支/预警状态：进度条变为红色 */
.progress-fill.over { background: #e74c3c; }

/* 百分比文本：灰色正常字体，显示在进度条下方 */
.percent-text {
  font-size: 32rpx;
  color: #666;
}

/* ===== 保存预算按钮 =====
 * 绿色主色调大按钮，位于页面底部。
 * 与添加记录页的保存按钮保持一致的样式风格。 */
.save-btn {
  margin-top: 30rpx;
  background: #07c160;
  color: #fff;
  font-size: 36rpx;
  border-radius: 12rpx;
}
