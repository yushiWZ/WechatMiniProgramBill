page {
  --green: #07c160;
  --red: #e74c3c;
  --blue: #3498db;
  --bg: #f5f5f5;
  --card-bg: #ffffff;
  --text: #333333;
  --text-light: #999999;
  --border: #eeeeee;

  background-color: var(--bg);
  font-size: 32rpx;
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.amount-income { color: var(--green); }
.amount-expense { color: var(--red); }
