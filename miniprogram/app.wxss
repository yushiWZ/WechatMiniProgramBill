/**
 * ========================================================================
 * 文件：app.wxss — 全局样式表
 * ========================================================================
 *
 * 本文件定义了整个"智能记账本"小程序的全局样式规则。
 * 所有页面都会自动继承这里的样式，无需在页面中单独 import。
 *
 * 主要包含：
 *   1. CSS 自定义属性（变量）—— 统一管理全局色彩、字号等设计令牌
 *   2. 页面级基础样式 —— 背景色、默认字号、字体栈
 *   3. 金额相关的工具类 —— 收入/支出的语义化颜色
 *
 * 设计决策：
 *   - 将颜色等设计令牌以 CSS 变量的形式定义在 page 选择器上，
 *     使得所有组件和页面都能通过 var(--xxx) 引用，
 *     未来换肤或调整品牌色只需修改此处的变量值即可
 *   - 使用 rpx 作为字号单位，使字体在不同屏幕宽度下等比缩放
 * ========================================================================
 */

/* ----------------------------------------------------------------
 * page 选择器 —— 对应小程序的根容器，类似于 Web 中的 <html>/<body>
 * 在此处定义的 CSS 变量可以被所有页面和自定义组件继承
 * ---------------------------------------------------------------- */
page {

  /* ---- 品牌色 / 语义色 ---- */
  --green: #07c160;       /* 微信绿 —— 用于收入金额、成功状态、主操作按钮等正向语义 */
  --red: #e74c3c;         /* 警示红 —— 用于支出金额、删除操作等负向/危险语义 */
  --blue: #3498db;        /* 信息蓝 —— 用于中性提示信息、链接等 */

  /* ---- 布局色 ---- */
  --bg: #f5f5f5;          /* 页面背景色 —— 浅灰色，降低长时间阅读的视觉疲劳 */
  --card-bg: #ffffff;     /* 卡片/面板背景色 —— 纯白，与 --bg 形成层次对比 */

  /* ---- 文字色 ---- */
  --text: #333333;        /* 主文本色 —— 用于标题、正文等主要内容 */
  --text-light: #999999;  /* 辅助文本色 —— 用于时间戳、占位符、次要说明等 */

  /* ---- 边框色 ---- */
  --border: #eeeeee;      /* 分隔线/边框色 —— 极浅灰，起到视觉分隔作用但不抢眼 */

  /* ---- 页面基础样式 ---- */
  background-color: var(--bg);   /* 全局背景色，所有页面默认继承 */
  font-size: 32rpx;              /* 默认字号 32rpx（≈16px），使用 rpx 实现响应式 */
  color: var(--text);            /* 默认文字颜色 */

  /* 字体栈：优先使用系统原生字体以获得最佳渲染效果和性能
   * -apple-system / BlinkMacSystemFont → iOS / macOS
   * Segoe UI → Windows
   * Roboto → Android
   * sans-serif → 兜底方案 */
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

/* ----------------------------------------------------------------
 * 金额工具类 —— 用于在账单列表中区分收入和支出的显示颜色
 * 使用示例：<text class="amount-income">+100.00</text>
 *           <text class="amount-expense">-50.00</text>
 * ---------------------------------------------------------------- */
.amount-income { color: var(--green); }   /* 收入金额 —— 绿色，表示资金流入 */
.amount-expense { color: var(--red); }    /* 支出金额 —— 红色，表示资金流出 */
